# Copy to .env.local and fill in values. Never commit .env.local.

# ── AI (required) ─────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SYSTEM_INSTRUCTION=        # AI persona — core IP, use \n for line breaks

# ── Server config (optional) ───────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
MAX_PDF_MB=5
MIN_RESUME_CHARS=200
MAX_RESUME_CHARS=12000
PDF_PARSE_TIMEOUT_MS=10000
ANALYZE_MAX_BODY_BYTES=32768
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Client config (optional) ───────────────────────────────────
NEXT_PUBLIC_MIN_RESUME_CHARS=
NEXT_PUBLIC_MAX_RESUME_CHARS=
NEXT_PUBLIC_MAX_PDF_MB=
NEXT_PUBLIC_APP_NAME=
